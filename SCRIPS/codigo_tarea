# Cargar librerías
install.packages("sf")
install.packages("ggplot2")
install.packages("viridis")
install.packages("ape")

library(ape)
library(sf)
library(ggplot2)

# item a)
# Asegúrate de que el archivo esté en tu directorio de trabajo
scallops <- read.table("scallops.txt", header = TRUE)
summary(scallops)

# item b)
# Convertir a objeto espacial
scallops_sf <- st_as_sf(scallops, coords = c("long", "lat"), crs = 4326)

# Crear el gráfico
ggplot(data = scallops_sf) +
  geom_sf(aes(color = tcatch, size = tcatch), alpha = 0.9) +
  scale_color_viridis_c(option = "plasma") + 
  theme_minimal() +
  labs(
    title = "Distribución Espacial de la Captura de Ostiones",
    subtitle = "Tamaño y color de los puntos representan la variable tcatch",
    color = "Captura",
    size = "Captura",
    x = "Longitud",
    y = "Latitud"
  )

# Crear una matriz de distancias geográficas entre todos los puntos
dist_matrix <- as.matrix(dist(cbind(scallops$long, scallops$lat)))

#  Crear la matriz de pesos (1/dist(Si-Sj))
weights <- 1 / dist_matrix

# Veamos que la diagonal dará "Inf" si la distancia de un punto a sí mismo es 0. 
# Por lo cual debemos reemplazar esos infinitos por 0.
diag(weights) <- 0

# Calcular el Índice de Moran
resultado_moran <- Moran.I(scallops$tcatch, weight = weights)

print(resultado_moran)

